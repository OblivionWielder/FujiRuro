                    "weeks": "<span color='#444444'>W{}</span>",
                    "weekdays": "<span color='#cc7000'><b>{}</b></span>",
                    "today": "<span color='#ffffff' background='#cc7000'><b>{}</b></span>"
                }
            },
            "on-click": "{{USER_HOME}}/oblivion/OSFunctionScripts/calendar_toggle.sh"
        },
        "custom/cpu_unified": {
            "exec": "{{USER_HOME}}/oblivion/OSFunctionScripts/waybar_cpu_unified.sh",
            "interval": 2,
            "return-type": "json",
            "format": "{}"
        },
        "memory": {
            "interval": 2,
            "format": "\uf0c9 {used:0.1f}G/{total:0.1f}G [{percentage}%]"
        },
        "custom/battery_unified": {
            "exec": "{{USER_HOME}}/oblivion/OSFunctionScripts/waybar_battery_unified.sh",
            "interval": 5,
            "return-type": "json",
            "on-click": "{{USER_HOME}}/oblivion/OSFunctionScripts/toggle_swaynag.sh 'Power Profiles' \"-B 'High Perf' '{{USER_HOME}}/oblivion/OSFunctionScripts/power_profile_manager.sh high' -B 'Normal' '{{USER_HOME}}/oblivion/OSFunctionScripts/power_profile_manager.sh normal' -B 'Low Power' '{{USER_HOME}}/oblivion/OSFunctionScripts/power_profile_manager.sh low'\"",
            "format": "{}"
        },
        "network": {
            "format-wifi": "\uf1eb {essid} [{signalStrength}%]",
            "format-ethernet": "\uf796 {ifname}",
            "tooltip-format": "\uf796 {ifname} via {gwaddr}",
            "format-linked": "\uf796 {ifname} (No IP)",
            "format-disconnected": "\u26a0 Disconnected",
            "on-click": "{{USER_HOME}}/oblivion/OSFunctionScripts/toggle_tui.sh nmtui nmtui"
        },
        "custom/volume": {
            "exec": "{{USER_HOME}}/oblivion/OSFunctionScripts/waybar_volume.sh",
            "interval": 1,
            "signal": 1,
            "format": "{}",
            "on-click": "{{USER_HOME}}/oblivion/OSFunctionScripts/audio_profile_switcher.sh menu",
            "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +1% && pkill -RTMIN+1 waybar",
            "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -1% && pkill -RTMIN+1 waybar",
            "return-type": "json"
        },
        "bluetooth": {
            "format": "\uf294 {status}",
            "format-connected": "\uf294 {device_alias}",
            "on-click": "{{USER_HOME}}/oblivion/OSFunctionScripts/toggle_gui.sh blueman-manager blueman-manager"
        },
        "custom/weather": {
            "format": "{}",
            "interval": 600,
            "exec": "{{USER_HOME}}/.config/waybar/weather.sh",
            "return-type": "json",
            "on-click": "{{USER_HOME}}/.config/waybar/weather.sh toggle",
            "signal": 2,
            "tooltip": true
        },
        "custom/keyboard": {
            "format": "\uf11c",
            "on-click": "pkill wvkbd-mobintl || wvkbd-mobintl -L 300",
            "tooltip": false
        },
