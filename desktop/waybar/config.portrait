        },
        "name": "bottom-row",
        "custom/backlight": {
            "exec": "{{USER_HOME}}/oblivion/OSFunctionScripts/waybar_backlight.sh",
            "return-type": "json",
            "interval": 2,
            "signal": 4,
            "on-scroll-up": "{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh up",
            "on-scroll-down": "{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh down",
            "on-click": "{{USER_HOME}}/oblivion/OSFunctionScripts/toggle_swaynag.sh 'Brightness Control' \"-B 'Min (1%)' '{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh set 1%' -B '-10%' '{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh set 10%-' -B '-5%' '{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh set 5%-' -B '-1%' '{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh set 1%-' -B 'Toggle Auto' '{{USER_HOME}}/oblivion/OSFunctionScripts/toggle_auto_brightness.sh' -B '+1%' '{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh set 1%+' -B '+5%' '{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh set 5%+' -B '+10%' '{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh set 10%+' -B 'Max (100%)' '{{USER_HOME}}/oblivion/OSFunctionScripts/backlight_control.sh set 100%'\""
        }
    }
]